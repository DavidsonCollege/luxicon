<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Raises the jetsam memory ceiling on supported devices — insurance for
         ~700 MB of speech models plus long recordings held in memory. -->
    <key>com.apple.developer.kernel.increased-memory-limit</key>
    <true/>
    <!-- Background GPU Access: lets a BGContinuedProcessingTask keep running
         MLX inference after the app is backgrounded (iOS 26+, supported
         devices only — gated at runtime via BGTaskScheduler.supportedResources). -->
    <key>com.apple.developer.background-tasks.continued-processing.gpu</key>
    <true/>
</dict>
</plist>
