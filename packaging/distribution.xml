<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Luxicon Sync Listener</title>
    <conclusion file="conclusion.html"/>
    <!-- MLX links transitively into luxicon-mcp; Apple Silicon only, matching
         the app's own hardware floor. -->
    <options customize="never" require-scripts="true" hostArchitectures="arm64"/>
    <domains enable_localSystem="true"/>
    <pkg-ref id="edu.davidson.luxicon.listener.pkg"/>
    <choices-outline>
        <line choice="default">
            <line choice="edu.davidson.luxicon.listener.pkg"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="edu.davidson.luxicon.listener.pkg" visible="false">
        <pkg-ref id="edu.davidson.luxicon.listener.pkg"/>
    </choice>
    <pkg-ref id="edu.davidson.luxicon.listener.pkg" version="@VERSION@" onConclusion="none">listener.pkg</pkg-ref>
</installer-gui-script>
